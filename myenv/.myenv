#!/bin/bash

# Colored manpages
export LESS_TERMCAP_mb=$'\e[1;32m'
export LESS_TERMCAP_md=$'\e[1;32m'
export LESS_TERMCAP_me=$'\e[0m'
export LESS_TERMCAP_so=$'\e[01;33m'
export LESS_TERMCAP_se=$'\e[0m'
export LESS_TERMCAP_us=$'\e[1;4;31m'
export LESS_TERMCAP_ue=$'\e[0m'

export EXA_COLORS="di=38;5;033:da=38;5;146"
export LS_COLORS=${LS_COLORS//di=01\;34:/di=38\;5\;033:}

export EDITOR=vim
export FZF_DEFAULT_OPTS

export HISTSIZE=100000
export SAVEHIST=$HISTSIZE

# Function to add a directory to PATH (append to end)
add_to_path() {
    if [ -d "$1" ] ; then
        case ":$PATH:" in
            *:"$1":*)
                ;;
            *)
                PATH="$PATH:$1"
                ;;
        esac
    fi
}

# Function to remove the last entry from PATH
remove_last_from_path() {
    # Remove any trailing colon, then strip the last ':'-separated field
    PATH=${PATH%:}
    if [ -z "$PATH" ]; then
        return
    fi
    PATH=${PATH%:*}
    export PATH
}

# Function to remove the first entry from PATH
remove_first_from_path() {
    # Remove any leading colon, then strip the first ':'-separated field
    PATH=${PATH#:}
    if [ -z "$PATH" ]; then
        return
    fi
    PATH=${PATH#*:}
    export PATH
}

# Add your custom directories to PATH
add_to_path "$HOME/bin"
add_to_path "$HOME/.local/bin"
add_to_path "$HOME/go/bin"
add_to_path "$HOME/st/stm32cubeclt/GNU-tools-for-STM32/bin"
add_to_path "$HOME/.cargo/bin"
add_to_path "/opt/nvim-linux-x86_64/bin"

source utils.sh

alias path="echo \$PATH | tr ':' '\n'"

#My aliases
alias ll='eza -laF --group-directories-first --header --long --icons=always'
alias la='eza -a --group-directories-first --icons=always'
alias l='eza -lF --group-directories-first --header --long --icons=always'

alias up='sudo apt-get update -y && sudo apt-get upgrade -y'
alias reload='echo "Sourcing environnement"; source ~/.zshrc'
alias cat='bat -pp'
alias wget='wget --hsts-file "$XDG_CONFIG_HOME"/wget/.wget-hsts'

alias gitka='gitk --all --max-count=15000'
alias s='s -p google'
alias clip='xclip -r -selection clipboard'

alias findall='find * | \
    fzf --prompt "All> " \
        --header "CTRL-D: Directories / CTRL-F: Files" \
        --bind "ctrl-d:change-prompt(Directories>)+reload(find * -type d)" \
        --bind "ctrl-f:change-prompt(Files>)+reload(find * -type f)" | xargs realpath | xclip -r -selection clipboard'


k() {
    ps -ef | fzf --reverse | awk '{print $2}' | xargs kill -9
}

gdiff() {
    git rev-parse --is-inside-work-tree &>/dev/null || return

    local path_to_repo
    path_to_repo="$(git rev-parse --show-toplevel)"

    local _preview_diff="git -C '$path_to_repo' diff -- {} | diff-so-fancy"
    local _view_diff="git -C '$path_to_repo' diff -- {} | diff-so-fancy | less -R -n"
    local _view_file="bat --style=numbers --color=always '$path_to_repo/{}'"

    git diff "$@" --name-only --diff-filter=d |
        fzf \
            --reverse \
            --tiebreak=index \
            --no-multi \
            --ansi \
            --border=rounded \
            --border-label=' Git Diff ' \
            --preview="$_preview_diff" \
            --preview-window=right:60% \
            --bind "shift-up:preview-up" \
            --bind "shift-down:preview-down" \
            --bind "ctrl-/:change-preview-window(right,60%|down,40%|hidden)" \
            --header-first \
            --header $'enter: view diff  |  ctrl-f: view file  |  ctrl-/: preview layout' \
            --bind "enter:execute:$_view_diff" \
            --bind "ctrl-f:execute:$_view_file"
}

fe() {
    local file
    file=$(fzf --preview 'bat --style=numbers --color=always {}')
    if [ -n "$file" ]; then
        editor "$file"
    fi
}

fcd() {
    local dir
    dir=$(find -L . -type d 2> /dev/null | fzf +m)

    if [ -n "$dir" ]; then
        cd "$dir" || exit
    fi
}

lg() {
    git rev-parse --is-inside-work-tree &>/dev/null || return
    if [ $# -eq 0 ]; then
        my_git_log -10000
    else
        my_git_log "$@"
    fi
}

my_git_log() {
    local _gitLogLineToHash="grep -o '[a-f0-9]\{12\}' | head -1"
    local _preview_commit="echo {} | $_gitLogLineToHash | xargs -I % sh -c 'git show --color=always % | diff-so-fancy'"
    local _view_commit="echo {} | $_gitLogLineToHash | xargs -I % sh -c 'git show --color=always % | diff-so-fancy' | less -R -n"
    local _copy_commit_hash="echo {} | $_gitLogLineToHash | xclip -r -selection clipboard"
    local _copy_commit_msg="echo {} | $_gitLogLineToHash | xargs -I HASH sh -c 'git log --pretty=format:\"%s%n%n%b\" -1 HASH' | xclip -r -selection clipboard"
    local _git_checkout="echo {} | $_gitLogLineToHash | xargs -I % sh -c 'git checkout %'"
    local _git_rebase="echo {} | $_gitLogLineToHash | xargs -I % sh -c 'git rebase -i %'"
    local _revert_commit="echo {} | $_gitLogLineToHash | xargs -I % sh -c 'git revert %'"

    git log \
    --abbrev=12 \
    --graph \
    --oneline \
    --color=always \
    --format="%C(cyan)%h %C(blue)%ar %C(auto)%d %C(yellow)%s %C(white)%ae" "$@" |
    fzf -i -e +s \
        --reverse \
        --tiebreak=index \
        --no-multi \
        --ansi \
        --border=rounded \
        --border-label=' Git Log ' \
        --preview="$_preview_commit" \
        --preview-window=right:45% \
        --bind "shift-up:preview-up" \
        --bind "shift-down:preview-down" \
        --bind "ctrl-/:change-preview-window(right,45%|down,40%|hidden)" \
        --header-first \
        --header $'enter: view  |  ctrl-y: copy hash  |  alt-y: copy msg  |  ctrl-x: checkout\nctrl-r: rebase  |  ctrl-z: revert  |  ctrl-/: preview layout' \
        --bind "enter:execute:$_view_commit" \
        --bind "ctrl-y:execute-silent:$_copy_commit_hash" \
        --bind "alt-y:execute-silent:$_copy_commit_msg" \
        --bind "ctrl-x:execute:$_git_checkout" \
        --bind "ctrl-r:execute($_git_rebase)+abort" \
        --bind "ctrl-z:execute:$_revert_commit"
}

proxy_config() {
    local PROXY_CREDENTIAL_FILE="$HOME/.proxy/.credentials"
    local PROXY_INFO_FILE="$HOME/.proxy/.info"
    mkdir -p "${PROXY_CREDENTIAL_FILE%/*}"
    test -f "$PROXY_CREDENTIAL_FILE" && chmod 600 "$PROXY_CREDENTIAL_FILE"
    printf "Proxy Username: "
    read -r ENTRY_user
    printf "Proxy Password: "
    read -rs ENTRY_pass
    echo
    printf "Proxy Server: "
    read -r ENTRY_server
    printf "No Proxy Domains: "
    read -r ENTRY_no_proxy_domain
    echo -n "${ENTRY_user}:${ENTRY_pass}" > "$PROXY_CREDENTIAL_FILE"
    echo -n "${ENTRY_server} ${ENTRY_no_proxy_domain}" > "$PROXY_INFO_FILE"
}

proxy_set() {
    local PROXY_CREDENTIAL_FILE="$HOME/.proxy/.credentials"
    local NO_PROXY_BASE=localhost,127.0.0.0/8
    local PROXY_INFO_FILE="$HOME/.proxy/.info"
    test -f "${PROXY_CREDENTIAL_FILE}" || return 1
    test -f "${PROXY_INFO_FILE}" || return 1
    http_proxy=http://$(sed "s,:.*,," "$PROXY_CREDENTIAL_FILE" | \
        od -A n -t x1 -w128 | \
        head -1 | \
        tr " " "%"):$(sed "s,[^:]\+:,," "$PROXY_CREDENTIAL_FILE" | \
        od -A n -t x1 -w128 | \
        head -1 | \
        tr " " "%")@$(sed "s, .*,," "$PROXY_INFO_FILE")
    https_proxy=http://$(sed "s,:.*,," "$PROXY_CREDENTIAL_FILE" | \
        od -A n -t x1 -w128 | \
        head -1 | \
        tr " " "%"):$(sed "s,[^:]\+:,," "$PROXY_CREDENTIAL_FILE" | \
        od -A n -t x1 -w128 | \
        head -1 | \
        tr " " "%")@$(sed "s, .*,," "$PROXY_INFO_FILE")
    ftp_proxy=http://$(sed "s,:.*,," "$PROXY_CREDENTIAL_FILE" | \
        od -A n -t x1 -w128 | \
        head -1 | \
        tr " " "%"):$(sed "s,[^:]\+:,," "$PROXY_CREDENTIAL_FILE" | \
        od -A n -t x1 -w128 | \
        head -1 | \
        tr " " "%")@$(sed "s, .*,," "$PROXY_INFO_FILE")
    use_proxy=on
    no_proxy=$(sed "s/.* \([^ ]*\)$/\1/" "$PROXY_INFO_FILE"),${NO_PROXY_BASE}

    export http_proxy
    export https_proxy
    export ftp_proxy
    export no_proxy
    export use_proxy
}

proxy_echo() {
    if [ -n "$https_proxy" ]; then echo "https_proxy=$https_proxy"; fi
    if [ -n "$http_proxy" ];  then echo "http_proxy=$http_proxy";  fi
    if [ -n "$ftp_proxy" ];   then echo "ftp_proxy=$ftp_proxy";    fi
    if [ -n "$no_proxy" ];    then echo "no_proxy=$no_proxy";      fi
    if [ -n "$use_proxy" ];   then echo "use_proxy=$use_proxy";    fi
}

proxy_unset() {
    unset https_proxy
    unset http_proxy
    unset ftp_proxy
    unset no_proxy
    unset use_proxy

}

# Function to speed up git log command (write commit graph in .git/objects/info/commit-graph)
speed_lg()
{
    git config --global core.commitGraph true
    git config --global gc.writeCommitGraph true
    git commit-graph write
}

download_some_backgrounds() {
    rawsite=$(mktemp)
    curl -s https://www.imoca.org/fr -o "$rawsite"

    cleanedsite=$(mktemp)
    tidy -q -o "$cleanedsite" "$rawsite" 2>/dev/null

    images_list=$(grep -o '/mediacenter/uploads/xxl/[^"]*\.jpeg' "$cleanedsite")
    images_list=$(echo "$images_list" | uniq)

    mkdir -p ~/Pictures/wallpapers/
    while IFS= read -r image_path; do
        [ -z "$image_path" ] && continue
        image_url="https://www.imoca.org${image_path}"
        echo_info "Downloading $image_url"
        wget -P ~/Pictures/wallpapers/ "$image_url"
    done <<< "$images_list"

    rm ~/Pictures/wallpapers/*.1
}

