{
    "C_Cpp.intelliSenseEngine": "disabled",
    "editor.fontFamily": "'DroidSansM Nerd Font Mono', 'monospace', monospace",
    "editor.largeFileOptimizations": false,
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "all",
    "explorer.confirmDelete": false,
    "git.openRepositoryInParentFolders": "never",
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": false
    },
    "search.followSymlinks": false,
    "security.workspace.trust.untrustedFiles": "open",
    "telemetry.telemetryLevel": "off",
    "terminal.integrated.fontFamily": "'DroidSansM Nerd Font Mono', 'monospace', monospace",
    "terminal.integrated.profiles.linux": {
        "zsh": {
            "path": "/usr/bin/zsh",
            "args": [
                "-l",
                "-i"
            ]
        },
    },
    "window.autoDetectColorScheme": true,
    "workbench.colorTheme": "Light Modern",
    "workbench.startupEditor": "none",
    "editor.inlayHints.enabled": "off",
    "github.copilot.nextEditSuggestions.enabled": true,
    "clangd.checkUpdates": false,
    "cmake.enableAutomaticKitScan": false,
    "cmake.configureOnOpen": false,
    "cmake.configureOnEdit": false,
    "gitlab.duoChat.enabled": false,
    "chat.editing.confirmEditRequestRemoval": false,
    "chat.viewSessions.orientation": "stacked",
    "claudeCode.preferredLocation": "panel",
    "claudeCode.selectedModel": "default",
}
