#!/bin/zsh

# Colored manpages
export LESS_TERMCAP_mb=$'\e[1;32m'
export LESS_TERMCAP_md=$'\e[1;32m'
export LESS_TERMCAP_me=$'\e[0m'
export LESS_TERMCAP_so=$'\e[01;33m'
export LESS_TERMCAP_se=$'\e[0m'
export LESS_TERMCAP_us=$'\e[1;4;31m'
export LESS_TERMCAP_ue=$'\e[0m'

export EXA_COLORS="di=38;5;033:da=38;5;146"
export LS_COLORS=${LS_COLORS//di=01\;34:/di=38\;5\;033:}

export EDITOR=vim
export LESS='-R -n -i'

export HISTSIZE=100000
export SAVEHIST=$HISTSIZE

# Function to add a directory to the beginning of PATH
add_first_to_path() {
    if [ -d "$1" ] ; then
        case ":$PATH:" in
            *:"$1":*)
                ;;
            *)
                PATH="$1:$PATH"
                ;;
        esac
    fi
}

# Function to add a directory to the end of PATH
add_last_to_path() {
    if [ -d "$1" ] ; then
        case ":$PATH:" in
            *:"$1":*)
                ;;
            *)
                PATH="$PATH:$1"
                ;;
        esac
    fi
}

# Function to remove the last entry from PATH
remove_last_from_path() {
    # Remove any trailing colon, then strip the last ':'-separated field
    PATH=${PATH%:}
    if [ -z "$PATH" ]; then
        return
    fi
    PATH=${PATH%:*}
    export PATH
}

# Function to remove the first entry from PATH
remove_first_from_path() {
    # Remove any leading colon, then strip the first ':'-separated field
    PATH=${PATH#:}
    if [ -z "$PATH" ]; then
        return
    fi
    PATH=${PATH#*:}
    export PATH
}

# Add your custom directories to PATH
add_first_to_path "$HOME/bin"
add_last_to_path "$HOME/.local/bin"
add_last_to_path "$HOME/go/bin"
add_last_to_path "$HOME/.cargo/bin"

source "$HOME/bin/utils.sh"

alias path="echo \$PATH | tr ':' '\n'"

#My aliases
alias ll='eza -laF --group-directories-first --header --long --icons=always'
alias la='eza -a --group-directories-first --icons=always'
alias l='eza -lF --group-directories-first --header --long --icons=always'
alias lt='eza --tree --level=2 --icons=always --group-directories-first'

alias up='sudo apt-get update -y && sudo apt-get upgrade -y'
alias reload='echo "Sourcing environnement"; source ~/.zshrc'
alias cat='bat -pp'
alias wget='wget --hsts-file "$XDG_CONFIG_HOME"/wget/.wget-hsts'

alias gitka='gitk --all --max-count=15000'
alias s='s -p google'
alias clip='xclip -r -selection clipboard'
alias paste='xclip -r -selection clipboard -o'

alias findall='find * | \
    fzf --prompt "All> " \
        --header "CTRL-D: Directories / CTRL-F: Files" \
        --bind "ctrl-d:change-prompt(Directories>)+reload(find * -type d)" \
        --bind "ctrl-f:change-prompt(Files>)+reload(find * -type f)" | xargs realpath | xclip -r -selection clipboard'

alias dot='code ~/.dotfiles'

tmp() { cd "$(mktemp -d)"; }

k() {
    local _preview="echo {} | awk '{print \$2}' | xargs -I % sh -c 'ps -p % -o pid,ppid,user,%cpu,%mem,etime,cmd --no-headers 2>/dev/null'"

    ps -ef | tail -n +2 |
        fzf \
            --reverse \
            --border=rounded \
            --border-label=' Kill Process ' \
            --header-first \
            --header $'enter: SIGTERM  |  ctrl-k: SIGKILL' \
            --preview="$_preview" \
            --preview-window=down:4:wrap \
            --bind "enter:execute-silent(echo {} | awk '{print \$2}' | xargs kill)+abort" \
            --bind "ctrl-k:execute-silent(echo {} | awk '{print \$2}' | xargs kill -9)+abort"
}

frg() {
    rg --color=always --line-number --no-heading "$@" |
        fzf \
            --reverse \
            --ansi \
            --border=rounded \
            --border-label=' Grep ' \
            --delimiter=: \
            --preview='bat --style=numbers --color=always --highlight-line {2} {1}' \
            --preview-window='right:60%,+{2}+3/3' \
            --bind "shift-up:preview-up" \
            --bind "shift-down:preview-down" \
            --bind "ctrl-/:change-preview-window(right,60%|down,40%|hidden)" \
            --header-first \
            --header $'enter: open in vscode  |  ctrl-/: preview layout' \
            --bind "enter:execute-silent:code --goto {1}:{2}"
}

fe() {
    local file
    file=$(fzf \
        --reverse \
        --border=rounded \
        --border-label=' Open File ' \
        --preview 'bat --style=numbers --color=always {}' \
        --preview-window=right:60%)
    if [ -n "$file" ]; then
        code "$file"
    fi
}

fcd() {
    local dir
    dir=$(find -L . -type d 2> /dev/null | fzf \
        --reverse \
        --border=rounded \
        --border-label=' Go To Dir ')

    if [ -n "$dir" ]; then
        cd "$dir" || return 1
    fi
}

download_some_backgrounds() {
    local rawsite
    rawsite=$(mktemp)
    curl -s https://www.imoca.org/fr -o "$rawsite"

    local cleanedsite
    cleanedsite=$(mktemp)
    tidy -q -o "$cleanedsite" "$rawsite" 2>/dev/null

    images_list=$(grep -o '/mediacenter/uploads/xxl/[^"]*\.jpeg' "$cleanedsite")
    images_list=$(echo "$images_list" | uniq)

    mkdir -p ~/Pictures/wallpapers/
    while IFS= read -r image_path; do
        [ -z "$image_path" ] && continue
        image_url="https://www.imoca.org${image_path}"
        echo_info "Downloading $image_url"
        wget -P ~/Pictures/wallpapers/ "$image_url"
    done <<< "$images_list"

    rm -f ~/Pictures/wallpapers/*.1
}

fssh() {
    local host
    host=$(grep "^Host " ~/.ssh/config | grep -v '[*?]' | awk '{print $2}' |
        fzf \
            --reverse \
            --border=rounded \
            --border-label=' SSH ' \
            --header-first \
            --header 'enter: connect')
    [ -n "$host" ] && ssh "$host"
}

lo-debug() {
    local rc_mode=0
    local threshold_ms=100

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                echo "Usage: lo-debug [-r] [threshold_ms]"
                echo ""
                echo "Identify LibreOffice I/O bottlenecks on rclone-mounted cloud storage."
                echo ""
                echo "Options:"
                echo "  -r, --rc      Low-overhead mode: poll rclone RC API stats (no strace)"
                echo "  threshold_ms  strace mode only — min duration in ms to report (default: 100)"
                echo ""
                echo "Both modes use fzf to pick among running rclone mounts."
                echo ""
                echo "strace mode (default) — attaches to LibreOffice and rclone in parallel:"
                echo "  \033[33mSLOW  891ms\033[0m  [libreoffice]    fsync(7) = 0         <- LO waiting for flush"
                echo "  \033[36mSLOW  887ms\033[0m  [rclone@gdrive]  recvfrom(12, ...) =  <- actual network wait"
                echo "  Correlated slow calls = network latency. LO-only = local cache pressure."
                echo "  LibreOffice: write, pwrite64, read, pread64, fsync, fdatasync"
                echo "  rclone:      recvfrom, recvmsg, sendto, sendmsg"
                echo ""
                echo "RC mode (-r) — polls rclone transfer stats every 2s with no process overhead."
                echo "  Requires RC_PORT=<port> in ~/.config/rclone/mounts/<remote>.env"
                echo "  and rclone started with --rc --rc-no-auth --rc-addr localhost:\${RC_PORT}"
                return 0
                ;;
            -r|--rc) rc_mode=1; shift ;;
            [0-9]*) threshold_ms="$1"; shift ;;
            *) shift ;;
        esac
    done

    local remote
    remote=$(systemctl --user list-units 'rclone@*.service' --state=running --no-legend \
        | awk '{sub(/rclone@/, "", $1); sub(/\.service/, "", $1); print $1}' \
        | fzf \
            --reverse \
            --border=rounded \
            --border-label=' LibreOffice I/O Debug ' \
            --preview="grep MOUNT_PATH ~/.config/rclone/mounts/{}.env 2>/dev/null" \
            --preview-window=down:3 \
            --header-first \
            --header "enter: $([ $rc_mode -eq 1 ] && echo 'poll RC stats' || echo "strace (threshold: ${threshold_ms}ms)")")
    [ -z "$remote" ] && return

    if [ $rc_mode -eq 1 ]; then
        local rc_port
        rc_port=$(grep '^RC_PORT=' ~/.config/rclone/mounts/${remote}.env 2>/dev/null | cut -d= -f2)
        if [ -z "$rc_port" ]; then
            echo "RC_PORT not set in ~/.config/rclone/mounts/${remote}.env"
            echo "Add RC_PORT=<port> and restart rclone@${remote}"
            return 1
        fi
        echo "Polling rclone@$remote RC stats (port $rc_port) every 2s. Ctrl-C to stop."
        while true; do
            printf "\033[2J\033[H"
            printf "rclone@$remote  $(date +%H:%M:%S)\n\n"
            rclone rc core/stats --url "http://localhost:${rc_port}" 2>/dev/null \
                | jq -r '"Speed:     \(.speed / 1048576 | . * 10 | floor / 10) MB/s",
                          "Transfers: \(.transfers)",
                          "Errors:    \(.errors)",
                          (if (.transferring | length) > 0 then "\nActive:" else "" end),
                          (.transferring[]? | "  \(.name)  \(.percentage // 0)%  \(.speedAvg / 1048576 | . * 10 | floor / 10) MB/s")' \
                || echo "RC API unreachable at localhost:${rc_port}"
            sleep 2
        done
        return
    fi

    local lo_pid
    lo_pid=$(pgrep -f soffice 2>/dev/null | head -1)
    if [ -z "$lo_pid" ]; then
        echo "LibreOffice is not running"
        return 1
    fi

    local rclone_pid
    rclone_pid=$(systemctl --user show "rclone@${remote}.service" --property=MainPID --value)
    if [ -z "$rclone_pid" ] || [ "$rclone_pid" -eq 0 ]; then
        echo "Could not find rclone PID for $remote"
        return 1
    fi

    echo "Tracing LibreOffice (PID $lo_pid) + rclone@$remote (PID $rclone_pid)"
    echo "Showing calls slower than ${threshold_ms}ms. Ctrl-C to stop.\n"

    {
        strace -T -qq -p "$lo_pid" \
            -e trace=write,pwrite64,read,pread64,fsync,fdatasync 2>&1 \
            | sed "s/^/[libreoffice] /" &
        strace -T -qq -p "$rclone_pid" \
            -e trace=recvfrom,recvmsg,sendto,sendmsg 2>&1 \
            | sed "s/^/[rclone@${remote}] /" &
        wait
    } | awk -v t="$threshold_ms" '
        match($0, /<([0-9]+)\.([0-9]{6})>$/, a) {
            ms = a[1]*1000 + int(a[2]/1000)
            if (ms >= t) {
                color = (index($0, "[rclone") > 0) ? "\033[36m" : "\033[33m"
                printf "%sSLOW %4dms\033[0m  %s\n", color, ms, $0
            }
        }
    '
}

source "$HOME/.myenv-git"
source "$HOME/.myenv-proxy"

compdef _files fe
compdef _cd fcd

if [ -f "$HOME/.myenv-perso" ]; then
    source "$HOME/.myenv-perso"
fi
